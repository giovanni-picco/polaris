{
	"$schema": "https://docs.renovatebot.com/renovate-schema.json",
	"extends": [
		"config:recommended"
	],
	"flux": {
		"managerFilePatterns": [
			"/flux-system/.+\\.yaml$/",
			"/infrastructure/.+\\.yaml$/",
			"/apps/.+\\.yaml$/"
		]
	},
	"kubernetes": {
		"managerFilePatterns": [
			"/flux-system//.+\\.yaml$/",
			"/infrastructure/.+\\.yaml$/",
			"/apps/.+\\.yaml$/"
		]
	}
}
